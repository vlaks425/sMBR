‚ĖĀIn ‚ĖĀthe ‚ĖĀmonth , ‚ĖĀChina ‚Äô s ‚ĖĀnon - man ufact uring ‚ĖĀCom merce ‚ĖĀIndex ‚ĖĀwas ‚ĖĀ5 4. 9% , ‚ĖĀup ‚ĖĀ0. 7 ‚ĖĀpercentage ‚ĖĀpoints ‚ĖĀfrom ‚ĖĀlast ‚ĖĀmonth , ‚ĖĀand ‚ĖĀrose ‚ĖĀby ‚ĖĀtwo ‚ĖĀconsecutive ‚ĖĀmonths .
‚ĖĀAccording ‚ĖĀto ‚ĖĀZ ha o , ‚ĖĀthe ‚ĖĀnon - man ufact uring ‚ĖĀsector ‚ĖĀas ‚ĖĀa ‚ĖĀwhole ‚ĖĀhas ‚ĖĀremained ‚ĖĀon ‚ĖĀtrack ‚ĖĀfor ‚ĖĀgood ‚ĖĀdevelopment .
‚ĖĀInd ustry ‚ĖĀbusiness ‚ĖĀactivity ‚ĖĀindices , ‚ĖĀsuch ‚ĖĀas ‚ĖĀroad ‚ĖĀtransport , ‚ĖĀsecurities , ‚ĖĀand ‚ĖĀreal ‚ĖĀestate , ‚ĖĀhave ‚ĖĀcontinued ‚ĖĀto ‚ĖĀfall ‚ĖĀbelow ‚ĖĀthe ‚ĖĀtipping ‚ĖĀpoint , ‚ĖĀand ‚ĖĀbusiness ‚ĖĀaggreg ates ‚ĖĀhave ‚ĖĀdeclined .
‚ĖĀAccording ‚ĖĀto ‚ĖĀHar u h iko ‚ĖĀK uro da , ‚ĖĀthe ‚ĖĀhead ‚ĖĀof ‚ĖĀthe ‚ĖĀBank ‚ĖĀof ‚ĖĀJapan , ‚ĖĀon ‚ĖĀNovember ‚ĖĀ5 - 11 5, ‚ĖĀthe ‚ĖĀcentral ‚ĖĀbank ‚ĖĀrealized ‚ĖĀthat ‚ĖĀa ‚ĖĀprolonged ‚ĖĀperiod ‚ĖĀof ‚ĖĀultra - lo ose ‚ĖĀmonetary ‚ĖĀpolicy ‚ĖĀcould ‚ĖĀsqueeze ‚ĖĀfinancial ‚ĖĀinstitutions ‚Äô ‚ĖĀprofitability ‚ĖĀand ‚ĖĀpotentially ‚ĖĀdestabilize ‚ĖĀthe ‚ĖĀcountry ‚Äô s ‚ĖĀbanking ‚ĖĀsystem .
‚ĖĀBut ‚ĖĀhe ‚ĖĀsays ‚ĖĀthat , ‚ĖĀgiven ‚ĖĀlow ‚ĖĀinflation ‚ĖĀand ‚ĖĀuncertainty ‚ĖĀin ‚ĖĀthe ‚ĖĀforeign ‚ĖĀeconomies , ‚ĖĀthe ‚ĖĀBOJ ‚ĖĀneeds ‚ĖĀto ‚ĖĀmaintain ‚ĖĀits ‚ĖĀmassive ‚ĖĀstimulus ‚ĖĀprogram , ‚ĖĀwhile ‚ĖĀpaying ‚ĖĀclose ‚ĖĀattention ‚ĖĀto ‚ĖĀits ‚ĖĀpolicies ‚Äô ‚ĖĀpros ‚ĖĀand ‚ĖĀcons .
‚ĖĀ‚Äú The ‚ĖĀBank ‚ĖĀof ‚ĖĀJapan ‚ĖĀfully ‚ĖĀrecognizes ‚ĖĀthat , ‚ĖĀgiven ‚ĖĀcontinued ‚ĖĀmonetary ‚ĖĀeasing , ‚ĖĀfinancial ‚ĖĀinstitutions ‚Äô ‚ĖĀpower ‚ĖĀwill ‚ĖĀbe ‚ĖĀincreasingly ‚ĖĀinfluenced ‚ĖĀby ‚ĖĀit ,‚ÄĚ ‚ĖĀK uro da ‚ĖĀsaid ‚ĖĀin ‚ĖĀhis ‚ĖĀspeech ‚ĖĀto ‚ĖĀcorporate ‚ĖĀleaders ‚ĖĀin ‚ĖĀK uro da .
‚ĖĀIf ‚ĖĀfinancial ‚ĖĀinstitutions ‚ĖĀwere ‚ĖĀto ‚ĖĀtake ‚ĖĀon ‚ĖĀrisk ‚ĖĀmore ‚ĖĀaggressively , ‚ĖĀhe ‚ĖĀclaimed , ‚ĖĀto ‚ĖĀcompensate ‚ĖĀfor ‚ĖĀthe ‚ĖĀimpact ‚ĖĀof ‚ĖĀyears ‚ĖĀof ‚ĖĀlow ‚ĖĀinterest ‚ĖĀrates ‚ĖĀon ‚ĖĀthe ‚ĖĀnarrow ing ‚ĖĀof ‚ĖĀprofits , ‚ĖĀthe ‚ĖĀbanking ‚ĖĀsystem ‚ĖĀcould ‚ĖĀbe ‚ĖĀin ‚ĖĀdanger ‚ĖĀof ‚ĖĀinstability ‚ĖĀin ‚ĖĀthe ‚ĖĀevent ‚ĖĀof ‚ĖĀa ‚ĖĀsevere ‚ĖĀnegative ‚ĖĀshock .
‚ĖĀ‚Äú D es pite ‚ĖĀthese ‚ĖĀrisks , ‚ĖĀcentral ‚ĖĀbanks ‚ĖĀwill ‚ĖĀkeep ‚ĖĀa ‚ĖĀclose ‚ĖĀeye ‚ĖĀon ‚ĖĀthe ‚ĖĀsituation ‚ĖĀand ‚ĖĀencourage ‚ĖĀfinancial ‚ĖĀinstitutions ‚ĖĀto ‚ĖĀtake ‚ĖĀthe ‚ĖĀnecessary ‚ĖĀmeasures ,‚ÄĚ ‚ĖĀhe ‚ĖĀdeclared .
‚ĖĀThe ‚ĖĀminutes ‚ĖĀof ‚ĖĀthe ‚ĖĀBank ‚ĖĀof ‚ĖĀJapan ‚Äô s ‚ĖĀCentral ‚ĖĀBank ‚ĖĀof ‚ĖĀJapan ‚ĖĀmeeting , ‚ĖĀreleased ‚ĖĀa ‚ĖĀlittle ‚ĖĀearlier ‚ĖĀthan ‚ĖĀa ‚ĖĀweek ‚ĖĀago , ‚ĖĀshowed ‚ĖĀthat ‚ĖĀthe ‚ĖĀcost ‚ĖĀof ‚ĖĀlong - term ‚ĖĀeasing ‚ĖĀwas ‚ĖĀrising ‚ĖĀin ‚ĖĀSeptember ‚Äô s ‚ĖĀsem bl ance .
‚ĖĀAccording ‚ĖĀto ‚ĖĀone ‚ĖĀcommission er , ‚ĖĀif ‚ĖĀthe ‚ĖĀeconomy ‚ĖĀcontinues ‚ĖĀto ‚ĖĀexpand , ‚ĖĀ‚Äú the ‚ĖĀBOJ ‚ĖĀwill ‚ĖĀhave ‚ĖĀmore ‚ĖĀroom ‚ĖĀfor ‚ĖĀpolicy ‚ĖĀflexibility ‚ĖĀin ‚ĖĀthe ‚ĖĀfuture .‚ÄĚ
‚ĖĀAccording ‚ĖĀto ‚ĖĀthe ‚ĖĀmeeting ‚Äô s ‚ĖĀrecord , ‚ĖĀanother ‚ĖĀcommission er ‚ĖĀargued ‚ĖĀthat , ‚ĖĀgiven ‚ĖĀthe ‚ĖĀlimits ‚ĖĀof ‚ĖĀpolicy ‚ĖĀcontinuity , ‚ĖĀthe ‚ĖĀBOJ ‚ĖĀshould ‚ĖĀdiscuss ‚ĖĀhow ‚ĖĀlong ‚ĖĀit ‚ĖĀcan ‚ĖĀmaintain ‚ĖĀits ‚ĖĀstimulus ‚ĖĀpolicy .
‚ĖĀHar u h iko ‚ĖĀK uro da ‚ĖĀclaims ‚ĖĀthat ‚ĖĀthe ‚ĖĀBank ‚ĖĀof ‚ĖĀJapan ‚ĖĀwill ‚ĖĀassess ‚ĖĀthe ‚ĖĀfinancial ‚ĖĀrisks ‚ĖĀposed ‚ĖĀby ‚ĖĀlax ‚ĖĀpolicies , ‚ĖĀwhile ‚ĖĀalso ‚ĖĀconsidering ‚ĖĀuncertainty ‚ĖĀsurrounding ‚ĖĀJapan ‚Äô s ‚ĖĀeconomic ‚ĖĀprospects , ‚ĖĀwhich ‚ĖĀcould ‚ĖĀaffect ‚ĖĀglobal ‚ĖĀdemand , ‚ĖĀowing ‚ĖĀto ‚ĖĀtrade ‚ĖĀfrict ions ‚ĖĀwith ‚ĖĀthe ‚ĖĀUnited ‚ĖĀStates ‚ĖĀand ‚ĖĀrising ‚ĖĀprotectionism .
‚ĖĀ‚Äú The ‚ĖĀimpact ‚ĖĀof ‚ĖĀsuch ‚ĖĀproblems ‚ĖĀon ‚ĖĀJapan ‚Äô s ‚ĖĀeconomy ‚ĖĀis ‚ĖĀtemporarily ‚ĖĀlimited ,‚ÄĚ ‚ĖĀHar u h iko ‚ĖĀK uro da ‚ĖĀclaims .
‚ĖĀ‚Äú B ut ‚ĖĀthe ‚ĖĀquestion ‚ĖĀcontinues , ‚ĖĀand ‚ĖĀthe ‚ĖĀimpact ‚ĖĀon ‚ĖĀJapan ‚Äô s ‚ĖĀeconomy ‚ĖĀis ‚ĖĀlikely ‚ĖĀto ‚ĖĀgrow ,‚ÄĚ ‚ĖĀhe ‚ĖĀadded .
‚ĖĀ‚Äú It ‚ĖĀis ‚ĖĀnecessary ‚ĖĀto ‚ĖĀpursue ‚ĖĀrobust ‚ĖĀmonetary ‚ĖĀeasing ‚ĖĀin ‚ĖĀa ‚ĖĀbalanced ‚ĖĀway , ‚ĖĀwhile ‚ĖĀconsidering ‚ĖĀpositive ‚ĖĀand ‚ĖĀnegative ‚ĖĀeffects ,‚ÄĚ ‚ĖĀK uro da ‚ĖĀsays .
‚ĖĀThough ‚ĖĀradical ‚ĖĀstimulus ‚ĖĀprograms ‚ĖĀhave ‚ĖĀincreased ‚ĖĀtheir ‚ĖĀdowns ides , ‚ĖĀsuch ‚ĖĀas ‚ĖĀthe ‚ĖĀerosion ‚ĖĀof ‚ĖĀfinancial ‚ĖĀinstitutions ‚Äô ‚ĖĀprofits ‚ĖĀby ‚ĖĀlong - term ‚ĖĀlow ‚ĖĀinterest ‚ĖĀrates , ‚ĖĀlow ‚ĖĀinflation ‚ĖĀhas ‚ĖĀforced ‚ĖĀthe ‚ĖĀBOJ ‚ĖĀto ‚ĖĀmaintain ‚ĖĀthe ‚ĖĀprogram .
‚ĖĀThe ‚ĖĀBank ‚ĖĀof ‚ĖĀJapan ‚ĖĀmaintained ‚ĖĀmonetary ‚ĖĀpolicy ‚ĖĀlast ‚ĖĀmonth ; ‚ĖĀand ‚ĖĀin ‚ĖĀthe ‚ĖĀface ‚ĖĀof ‚ĖĀthe ‚ĖĀrisks ‚ĖĀposed ‚ĖĀby ‚ĖĀthe ‚ĖĀglobal ‚ĖĀtrade ‚ĖĀwar , ‚ĖĀHar u h iko ‚ĖĀK uro da ‚ĖĀruled ‚ĖĀout ‚ĖĀthe ‚ĖĀpossibility ‚ĖĀof ‚ĖĀa ‚ĖĀrecent ‚ĖĀhike .
